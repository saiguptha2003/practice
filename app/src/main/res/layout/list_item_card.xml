<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/list_item_card"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_marginLeft="38dp"
        android:layout_marginRight="38dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/backgroundcountry"
        android:layout_marginTop="16dp"

        >
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"

            android:orientation="horizontal">
            <ImageView
                android:layout_width="38dp"
                android:layout_marginLeft="20dp"
                android:layout_height="40dp"
                android:src="@drawable/angolo"
                android:id="@+id/Flag"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="6dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="132dp"
                    android:id="@+id/CountryName"
                    android:layout_height="21dp"
                    android:layout_marginTop="5dp"
                    android:lineHeight="21dp"
                    android:textAlignment="center"

                    android:text="Good Morning"
                    android:textColor="#000000"
                    android:textFontWeight="400"
                    android:textSize="14sp" />


            </LinearLayout>



        </LinearLayout>

        <RadioButton
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginLeft="28dp"
            android:layout_marginRight="38dp"
            android:outlineAmbientShadowColor="#F42053"
            android:outlineSpotShadowColor="#F42053"
            android:drawableTint="#F42053"
            android:src="@drawable/ic_launcher_background"/>
    </RelativeLayout>
</LinearLayout>